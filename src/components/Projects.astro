---
import projectsData from '../data/projects.json';
import personalData from '../data/personal.json';
import { augmentProjectsWithImages, type ProjectEntry } from '../lib/fetchGitHub';
import { withBase } from '../lib/assetPath';

interface Props {
  featuredOnly?: boolean;
}
const { featuredOnly = false } = Astro.props;

// const allProjectsData = await augmentProjectsWithImages(projectsData as ProjectEntry[]);
type ProjectCardEntry = ProjectEntry & { categories: string[] };

const allProjectsData = (projectsData as ProjectEntry[]).map((project) => ({
  ...project,
  categories: Array.isArray(project.category) ? project.category : [project.category],
})) as ProjectCardEntry[];
const displayProjects = featuredOnly
  ? allProjectsData.filter((p) => p.sliderImage)
  : allProjectsData;

// Filter values must match the `category` field used in projects.json entries.
const filters = [
  { label: 'All', value: 'all' },
  { label: 'Computer Vision', value: 'computer_vision' },
  { label: 'Web', value: 'web' },
  { label: 'Image Processing', value: 'image_processing' },
  { label: 'Deep Learning', value: 'deep_learning' },
];

const categoryValueToLabel = Object.fromEntries(
  filters.filter((f) => f.value !== 'featured' && f.value !== 'all').map((f) => [f.value, f.label])
);

function getProjectCategories(project: ProjectCardEntry) {
  return project.categories.map((category) => category.trim().toLowerCase()).filter(Boolean);
}

function getCategoryLabel(value: string): string {
  return categoryValueToLabel[value.toLowerCase()] || value;
}

const projectsJson = JSON.stringify(
  allProjectsData.map((p) => ({
    ...p,
    sliderImage: p.sliderImage ? withBase(p.sliderImage) : p.sliderImage,
    featuredImage: p.featuredImage ? withBase(p.featuredImage) : p.featuredImage,
    images: p.images ? p.images.map((img) => withBase(img)) : [],
    slides: p.slides ?? [],
  }))
);
---

<section id="projects" class="py-24 bg-slate-900/30" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">My work</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Featured Projects</h2>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-10 reveal" style="transition-delay:0.1s;">
      {
        filters.map((f) => (
          <button
            class="filter-btn"
            data-filter={f.value}
            aria-pressed={f.value === 'all' ? 'true' : 'false'}
          >
            {f.label}
            <span class="filter-count" data-count={f.value} />
          </button>
        ))
      }
    </div>

    <div
      id="projects-grid"
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
    >
      {
        displayProjects.map((project, i) => (
          <div
            class="project-card reveal"
            data-categories={getProjectCategories(project).join('|')}
            data-featured={(project as any).featured ? 'true' : 'false'}
            data-index={i}
            style={`transition-delay: ${(i % 3) * 0.07}s;`}
            role="button"
            tabindex="0"
            aria-label={`Open details for ${project.title}`}
          >
            <div class="project-card-inner">
              {project.featuredImage && (
                <div class="card-img-wrap" aria-hidden="true">
                  <img
                    src={withBase(project.featuredImage!)}
                    alt=""
                    loading="lazy"
                    width="600"
                    height="400"
                    class="card-img"
                  />
                </div>
              )}

              <div class="p-5 flex flex-col flex-1 relative z-10">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <p class="text-xs font-bold text-highlight uppercase tracking-widest leading-tight">
                    {project.company}
                  </p>
                </div>

                <h3 class="project-title text-lg font-bold mb-2 leading-snug">{project.title}</h3>

                <p class="card-desc text-slate-400 text-sm leading-relaxed flex-1 mb-4">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>

              <div class="project-footer">
                <div class="footer-shimmer" aria-hidden="true" />
                <span class="category-badge">
                  {project.categories.map(getCategoryLabel).join(' · ')}
                </span>
                {/* {project.icon && icons[project.icon] && (
                  <div class="card-icon shrink-0">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="w-5 h-5"
                      set:html={icons[project.icon]}
                    />
                  </div>
                )} */}
                {/* <span class="view-hint">
                  <span class="view-hint-text">Click for link to project</span>
                  <svg
                    class="view-hint-arrow"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    />
                  </svg>
                </span> */}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p id="projects-empty" class="hidden text-center text-slate-600 text-sm mt-12">
      No projects in this category yet.
    </p>
  </div>
</section>

<div
  id="project-modal"
  class="modal-backdrop"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  hidden
>
  <div class="modal-container" id="modal-container">
    <button class="modal-close" id="modal-close" aria-label="Close">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="modal-hero" id="modal-hero">
      <div class="modal-hero-overlay"></div>
      <div class="modal-hero-content">
        <div id="modal-category-badge" class="modal-cat-badge"></div>
        <h2 id="modal-title" class="modal-heading"></h2>
        <p id="modal-company" class="modal-company"></p>
      </div>
    </div>

    <div class="modal-body">
      <div id="modal-carousel" class="modal-carousel hidden">
        <div class="carousel-viewport">
          <img id="carousel-img" src="" alt="" class="carousel-img" />
          <button
            id="carousel-prev"
            class="carousel-nav carousel-nav-prev"
            aria-label="Previous image"
          >
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <button id="carousel-next" class="carousel-nav carousel-nav-next" aria-label="Next image">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </button>
        </div>
        <div class="carousel-footer">
          <span id="carousel-caption" class="carousel-caption"></span>
          <div id="carousel-strip" class="carousel-strip"></div>
          <span id="carousel-counter" class="carousel-counter"></span>
        </div>
      </div>
      <p id="modal-description" class="modal-description"></p>
      <div id="modal-tags" class="modal-tags"></div>

      <div class="modal-cta-wrap">
        <div class="modal-cta-buttons">
          <a
            id="modal-site-link"
            href="#"
            target="_blank"
            rel="noopener"
            class="modal-cta-link hidden"
          >
            <img
              src={withBase('/images/assets/icon--link.png')}
              alt=""
              width={18}
              height={18}
              class="modal-link-icon"
            />
            <span>View project site</span>
            <svg class="modal-cta-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </a>
          <a
            id="modal-github-link"
            href="#"
            target="_blank"
            rel="noopener"
            class="modal-cta-link hidden"
          >
            <svg
              class="modal-link-icon modal-github-icon"
              fill="currentColor"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            <span>View GitHub repo</span>
            <svg class="modal-cta-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </a>
        </div>
        <p id="modal-no-link" class="modal-no-link hidden">Private / No public link available.</p>
      </div>
    </div>
  </div>
</div>

<!-- define:vars injects the server-rendered JSON blob as a JS variable in this inline script.
     is:inline is required alongside define:vars; without it Astro would bundle the script
     and the injected variable would not be in scope. -->
<script
  is:inline
  define:vars={{ projectsJson, githubUser: personalData.github, categoryValueToLabel }}
>
  const projects = JSON.parse(projectsJson);

  document.querySelectorAll('#projects .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    io.observe(el);
  });

  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card[data-categories]');
  const empty = document.getElementById('projects-empty');
  let active = null;

  function getCardCategories(card) {
    return (card.dataset.categories || '')
      .split('|')
      .map((category) => category.trim().toLowerCase())
      .filter(Boolean);
  }

  document.querySelectorAll('.filter-count').forEach((el) => {
    const cat = el.dataset.count;
    const filterKey = (cat || '').trim().toLowerCase();
    let n;
    if (filterKey === 'all') n = cards.length;
    else if (filterKey === 'featured')
      n = [...cards].filter((c) => c.dataset.featured === 'true').length;
    else
      n = [...cards].filter((c) => {
        const categories = getCardCategories(c);
        return categories.includes(filterKey);
      }).length;
    el.textContent = `${n}`;
  });

  function applyFilter(filter) {
    const filterKey = (filter || '').trim().toLowerCase();
    if (filterKey === active) return;
    active = filterKey;
    filterBtns.forEach((b) => {
      const on = (b.dataset.filter || '').trim().toLowerCase() === filterKey;
      b.classList.toggle('filter-active', on);
      b.setAttribute('aria-pressed', String(on));
    });
    let visible = 0;
    cards.forEach((card) => {
      const categories = getCardCategories(card);
      const matches =
        filterKey === 'all' ||
        (filterKey === 'featured' && card.dataset.featured === 'true') ||
        categories.includes(filterKey);
      card.classList.remove('pf-enter');
      if (!matches) {
        card.classList.add('pf-hidden');
      } else {
        card.classList.remove('pf-hidden');
        card.style.setProperty('--enter-delay', `${visible * 0.05}s`);
        // Force a reflow so the browser registers the class removal before re-adding pf-enter.
        // Without this, the CSS animation does not restart when re-showing an already-visible card.
        void card.offsetWidth;
        card.classList.add('pf-enter');
        visible++;
      }
    });
    if (empty) empty.classList.toggle('hidden', visible > 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter));
  });

  applyFilter('all');
  document.querySelector('[data-filter="all"]')?.classList.add('filter-active');

  const modal = document.getElementById('project-modal');
  const container = document.getElementById('modal-container');
  const closeBtn = document.getElementById('modal-close');
  const modalHero = document.getElementById('modal-hero');
  const modalCat = document.getElementById('modal-category-badge');
  const modalTitle = document.getElementById('modal-title');
  const modalCo = document.getElementById('modal-company');
  const modalDesc = document.getElementById('modal-description');
  const modalTags = document.getElementById('modal-tags');
  const modalSiteLink = document.getElementById('modal-site-link');
  const modalGithubLink = document.getElementById('modal-github-link');
  const modalNoLink = document.getElementById('modal-no-link');
  const carouselEl = document.getElementById('modal-carousel');
  const carouselImgEl = document.getElementById('carousel-img');
  const carouselStripEl = document.getElementById('carousel-strip');
  const carouselCaptionEl = document.getElementById('carousel-caption');
  const carouselCounterEl = document.getElementById('carousel-counter');
  const carouselPrevBtn = document.getElementById('carousel-prev');
  const carouselNextBtn = document.getElementById('carousel-next');

  let carouselImages = [];
  let carouselSlides = [];
  let carouselIndex = 0;

  function goToCarouselSlide(idx) {
    carouselIndex = Math.max(0, Math.min(idx, carouselImages.length - 1));
    carouselImgEl.src = carouselImages[carouselIndex];
    carouselStripEl.querySelectorAll('.carousel-dot').forEach((d, i) => {
      d.classList.toggle('active', i === carouselIndex);
    });
    carouselCaptionEl.textContent = carouselSlides[carouselIndex] ?? '';
    carouselCounterEl.textContent = `${carouselIndex + 1} / ${carouselImages.length}`;
    carouselPrevBtn.disabled = carouselIndex === 0;
    carouselNextBtn.disabled = carouselIndex === carouselImages.length - 1;
  }

  function openModal(idx) {
    const p = projects[idx];
    if (!p) return;
    const categories = Array.isArray(p.categories)
      ? p.categories
      : Array.isArray(p.category)
        ? p.category
        : [p.category];

    const img = p.featuredImage || null;
    if (img) {
      modalHero.style.backgroundImage = `url('${img}')`;
      modalHero.style.display = '';
    } else {
      modalHero.style.backgroundImage = '';
      modalHero.style.display = 'none';
    }

    const categoryLabels = categories.map((cat) => categoryValueToLabel[cat] || cat);
    modalCat.textContent = categoryLabels.join(' · ');
    modalTitle.textContent = p.title;
    modalCo.textContent = p.company;
    modalDesc.textContent = p.description;

    modalTags.innerHTML = '';
    for (const t of p.tags) {
      const span = document.createElement('span');
      span.className = 'tag';
      span.textContent = t;
      modalTags.appendChild(span);
    }

    const imgs = (p.images || []).filter(Boolean);
    if (imgs.length > 0) {
      carouselImages = imgs;
      carouselSlides = p.slides || [];
      carouselEl.classList.remove('hidden');
      carouselStripEl.innerHTML = '';
      imgs.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot';
        dot.setAttribute('aria-label', carouselSlides[i] ? carouselSlides[i] : `Image ${i + 1}`);
        dot.addEventListener('click', () => goToCarouselSlide(i));
        carouselStripEl.appendChild(dot);
      });
      goToCarouselSlide(0);
    } else {
      carouselEl.classList.add('hidden');
      carouselImages = [];
      carouselSlides = [];
    }

    const hasSite = !!p.projectSite;
    const hasGithub = !!p.githubRepo;

    if (hasSite) {
      modalSiteLink.href = p.projectSite;
      modalSiteLink.classList.remove('hidden');
    } else {
      modalSiteLink.classList.add('hidden');
    }

    if (hasGithub) {
      modalGithubLink.href = `https://github.com/${githubUser}/${p.githubRepo}`;
      modalGithubLink.classList.remove('hidden');
    } else {
      modalGithubLink.classList.add('hidden');
    }

    if (!hasSite && !hasGithub) {
      modalNoLink.classList.remove('hidden');
    } else {
      modalNoLink.classList.add('hidden');
    }

    // The `hidden` attribute (not a CSS class) is used here because the modal-backdrop rule
    // sets `display:none !important` on `[hidden]`, which gives correct AT (screen reader) semantics.
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden'; // prevent page scroll while modal is open
    void container.offsetWidth;
    modal.classList.add('modal-open');
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('modal-open');
    modal.classList.add('modal-closing');
    setTimeout(() => {
      modal.setAttribute('hidden', '');
      modal.classList.remove('modal-closing');
      document.body.style.overflow = '';
    }, 280);
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      openModal(parseInt(card.dataset.index, 10));
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(parseInt(card.dataset.index, 10));
      }
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
  });
  carouselPrevBtn.addEventListener('click', () => goToCarouselSlide(carouselIndex - 1));
  carouselNextBtn.addEventListener('click', () => goToCarouselSlide(carouselIndex + 1));
</script>

<style is:global>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    background: var(--bg-section);
    border: 1px solid var(--border);
    cursor: pointer;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .filter-btn:hover {
    color: var(--text-muted);
    background: var(--bg-card);
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }
  .filter-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .filter-btn.filter-active {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.4);
  }
  .filter-count {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-dimmer);
    background: var(--border);
    border-radius: 9999px;
    padding: 0 0.35rem;
    min-width: 1.1rem;
    text-align: center;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }
  .filter-btn.filter-active .filter-count {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.15);
  }

  .project-card {
    transition: opacity 0.2s ease;
    position: relative;
    cursor: pointer;
  }
  .project-card:focus-visible .project-card-inner {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .project-card.pf-hidden {
    display: none;
  }
  .project-card.pf-enter {
    animation: card-enter 0.4s cubic-bezier(0.22, 1, 0.36, 1) var(--enter-delay, 0s) both;
  }
  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .float-icon-wrap,
  .float-icon,
  .float-icon-mdi {
    display: none;
  }

  .category-badge {
    font-size: 0.56rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: rgba(99, 102, 241, 0.05);
    border: 1px solid rgba(99, 102, 241, 0.12);
    opacity: 0.7;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    position: relative;
    z-index: 1;
    white-space: nowrap;
    transition:
      color 0.3s ease,
      background 0.3s ease,
      border-color 0.3s ease,
      opacity 0.3s ease;
  }
  .project-card:hover .category-badge {
    color: var(--text-muted);
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.3);
    opacity: 1;
  }

  .card-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.08);
    transition: transform 0.75s ease;
  }
  .project-card:hover .card-img {
    transform: scale(1);
  }
  .project-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    overflow: hidden;
    transition:
      transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }
  .project-card:hover .project-card-inner {
    transform: translateY(-5px);
    border-color: rgba(99, 102, 241, 0.4);
    box-shadow:
      0 20px 52px rgba(0, 0, 0, 0.38),
      0 0 0 1px rgba(99, 102, 241, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .project-title {
    color: var(--text);
